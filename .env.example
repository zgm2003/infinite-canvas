# 管理员账号，首次启动会自动创建。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=infinite-canvas

# JWT 登录密钥和过期时间，正式部署请修改 JWT_SECRET。
JWT_SECRET=infinite-canvas
JWT_EXPIRE_HOURS=168

# 后端监听端口
PORT=8080

# 前端开发代理默认使用 http://127.0.0.1:8080，如后端开发端口不同，启动前端时可单独设置 API_BASE_URL。
# API_BASE_URL=http://127.0.0.1:8080

# 数据库配置，Docker Compose 默认连接宿主机已有 MySQL。
# 先在目标 MySQL 中创建数据库：
# CREATE DATABASE IF NOT EXISTS infinite_canvas CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
STORAGE_DRIVER=mysql
MYSQL_DSN=root:change_me@tcp(host.docker.internal:3307)/infinite_canvas?charset=utf8mb4&parseTime=True&loc=Local
# DATABASE_DSN 保留给旧镜像或非 MySQL 配置；当前代码里 MYSQL_DSN 优先。
DATABASE_DSN=root:change_me@tcp(host.docker.internal:3307)/infinite_canvas?charset=utf8mb4&parseTime=True&loc=Local
MYSQL_MAX_OPEN_CONNS=20
MYSQL_MAX_IDLE_CONNS=10
MYSQL_CONN_MAX_LIFETIME=1h
# 直接在宿主机 go run . 时可改用：
# MYSQL_DSN=root:change_me@tcp(127.0.0.1:3307)/infinite_canvas?charset=utf8mb4&parseTime=True&loc=Local
# sqlite: DATABASE_DSN=data/infinite-canvas.db
# postgres: DATABASE_DSN=postgres://user:password@127.0.0.1:5432/infinite_canvas?sslmode=disable

# 是否允许服务启动时自动迁移。默认关闭；开发想省步骤可临时改成 true。
# 受控部署先显式执行：go run . migrate 或 /app/server migrate。
DB_AUTO_MIGRATE=false
